{
  "name": "do-sync",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev:web": "pnpm --filter do-sync-web dev",
    "dev:worker": "pnpm --filter do-sync-worker exec wrangler dev --config ../../apps/worker/wrangler.jsonc",
    "build": "pnpm --filter do-sync-web build",
    "typecheck": "pnpm --filter do-sync-web typecheck && pnpm --filter do-sync-worker typecheck",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "clear:demo": "node scripts/clear-demo.mjs",
    "seed:demo": "node scripts/seed-demo.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
